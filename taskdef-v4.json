{
  "family": "youtube-trimmer-task",
  "executionRoleArn": "arn:aws:iam::949160680094:role/service-role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "2048",
  "volumes": [],
  "placementConstraints": [],
  "containerDefinitions": [
    {
      "name": "youtube-trimmer",
      "image": "949160680094.dkr.ecr.eu-west-1.amazonaws.com/youtube-trimmer:proxy-20260702-012135",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "command": [
        "sh",
        "-lc",
        "umask 077; printf \"%s%s%s%s%s%s%s\" \"$YT_DLP_COOKIES_P00\" \"$YT_DLP_COOKIES_P01\" \"$YT_DLP_COOKIES_P02\" \"$YT_DLP_COOKIES_P03\" \"$YT_DLP_COOKIES_P04\" \"$YT_DLP_COOKIES_P05\" \"$YT_DLP_COOKIES_P06\" | base64 -d | gunzip > /tmp/cookies.txt; exec npm start"
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "YT_DLP_COOKIES_FILE",
          "value": "/tmp/cookies.txt"
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "secrets": [
        {
          "name": "YT_DLP_COOKIES_P00",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:949160680094:secret:yt-dlp-cookies-p00-NvjOLN"
        },
        {
          "name": "YT_DLP_COOKIES_P01",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:949160680094:secret:yt-dlp-cookies-p01-KRbEaW"
        },
        {
          "name": "YT_DLP_COOKIES_P02",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:949160680094:secret:yt-dlp-cookies-p02-0dL2UL"
        },
        {
          "name": "YT_DLP_COOKIES_P03",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:949160680094:secret:yt-dlp-cookies-p03-U5SuIa"
        },
        {
          "name": "YT_DLP_COOKIES_P04",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:949160680094:secret:yt-dlp-cookies-p04-8ijZPV"
        },
        {
          "name": "YT_DLP_COOKIES_P05",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:949160680094:secret:yt-dlp-cookies-p05-JPeGl8"
        },
        {
          "name": "YT_DLP_COOKIES_P06",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:949160680094:secret:yt-dlp-cookies-p06-kQhdXr"
        },
        {
          "name": "YT_DLP_PROXY",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:949160680094:secret:yt-dlp-proxy-OMYRKc"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/youtube-trimmer",
          "awslogs-region": "eu-west-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "systemControls": []
    }
  ]
}
