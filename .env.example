# YouTube auth for age-restricted or sign-in-required videos.
# Use the browser where you are signed into YouTube (local dev):
YT_DLP_COOKIES_FROM_BROWSER=chrome

# Or point to a Netscape-format cookies.txt (Docker / production):
# YT_DLP_COOKIES_FILE=/path/to/cookies.txt

# --- Fix for the datacenter-IP "confirm you're not a bot" error on AWS ---
# Route yt-dlp through a residential/rotating proxy so YouTube sees a
# non-datacenter IP. This is applied to ALL yt-dlp calls (video-info + download)
# and requires NO separate worker. Format: http://user:pass@host:port
# (socks5://... also works). Combine with cookies above for best results.
# YT_DLP_PROXY=http://user:pass@residential-proxy.example.com:8000

# --- Optional: offload yt-dlp to an external worker (see /worker) ---
# Set these to run yt-dlp on a non-datacenter / residential IP path so YouTube
# anti-bot checks pass. When YTDLP_WORKER_URL is set, the app calls the worker
# instead of running yt-dlp locally, and the local cookie settings above are
# NOT used (configure cookies/proxy on the worker instead).
# YTDLP_WORKER_URL=https://your-worker.example.com
# YTDLP_WORKER_API_KEY=your-long-random-secret
