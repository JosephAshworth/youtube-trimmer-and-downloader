AWS_REGION=eu-west-1
AWS_ACCOUNT_ID=123456789012

# ECR
ECR_REPOSITORY=youtube-trimmer
IMAGE_TAG=latest

# ECS
ECS_CLUSTER=youtube-trimmer-cluster
ECS_SERVICE=youtube-trimmer-service
ECS_TASK_FAMILY=youtube-trimmer-task

# Optional: set to the container definition name in your task definition.
# Defaults to "youtube-trimmer" if omitted.
CONTAINER_NAME=youtube-trimmer
