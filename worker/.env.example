# Port the worker listens on
PORT=8080

# Shared secret. The Next.js app must send the SAME value in the X-API-Key
# header (YTDLP_WORKER_API_KEY there). Generate one with:
#   openssl rand -hex 32
YTDLP_WORKER_API_KEY=change-me-to-a-long-random-string

# Optional: comma-separated IP allowlist. Set this to your AWS NAT gateway
# Elastic IP(s) so only your ECS tasks can reach the worker.
# YTDLP_WORKER_IP_ALLOWLIST=203.0.113.10,203.0.113.11

# --- YouTube auth / anti-bot mitigation (the reason this worker exists) ---

# Netscape-format cookies.txt exported from a signed-in YouTube session.
# YT_DLP_COOKIES_FILE=/app/cookies.txt

# Or pull cookies from a local browser profile (local dev only).
# YT_DLP_COOKIES_FROM_BROWSER=chrome

# Residential / rotating proxy for yt-dlp egress. Use this when the worker host
# itself is not on a residential IP. Format: http://user:pass@host:port
# YT_DLP_PROXY=http://user:pass@proxy.example.com:8000

# Optional override for the yt-dlp binary path.
# YT_DLP_BIN=yt-dlp
